# ================================================
#    老年人跌倒检测系统 - 环境配置文件
# ================================================
#
# 使用说明：
# 1. 复制此文件为 .env 文件
# 2. 根据需要修改配置值
# 3. 运行 start.bat 或 docker-compose up -d 启动服务
#

# ================================================
# MySQL 数据库配置
# ================================================
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=elderly_care
MYSQL_USER=admin
MYSQL_PASSWORD=admin123

# ================================================
# 服务端口配置
# ================================================
# 前端端口（默认80）
FRONTEND_PORT=80

# 后端API端口（默认8080）
BACKEND_PORT=8080

# 数据库端口（默认3306）
MYSQL_PORT=3306

# ================================================
# Spring Boot JPA 配置
# ================================================
# 可选值: update(推荐开发用) / validate / none / create / create-drop
JPA_DDL_AUTO=update

# ================================================
# AI 模型配置
# ================================================
# 智谱AI API密钥（替换为您自己的密钥）
AI_API_KEY=your_api_key_here

# AI API 地址（默认使用智谱AI）
AI_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# AI 模型名称（glm-4-flash / glm-4 / glm-3-turbo）
AI_MODEL=glm-4-flash

# ================================================
# 时区配置
# ================================================
TZ=Asia/Shanghai